# SuperTale / NovelVideo newAPI 环境变量示例
#
# 复制为 .env 后填写真实值。
# SuperTale 侧只配置 newAPI 网关、newAPI 逻辑模型名、参考媒体 relay 和运行环境参数。
# 上游渠道、真实模型、映射、价格和 token 权限在 newAPI 后台配置。


# =============================================================================
# 1. newAPI 统一网关
# =============================================================================

# 内置 newapi 后台宿主端口（仅 docker compose 生效）。容器内固定 3000，这里只改宿主映射。
# 默认 3000；端口冲突时改成别的（例如 30000）。
# ST_NEWAPI_PORT=3000

# 自定义/BYO 模型网关地址(OpenAI 兼容,末尾保留 /v1)。
# 官方渠道无需配置网关地址,在网页「设置 → 模型配置 → 官方渠道」填写 DC key 即可。
# 只有使用自定义 NewAPI / BYO 网关时才填写本项,例如 https://your-gateway/v1。
NEWAPI_BASE_URL=

# DC key / 网关 token,不要提交真实密钥。留空 = 启动后在网页「模型配置 → 官方渠道」粘贴。
# 到 https://relayclaw.cdnfg.com 注册 / 购买 DC key。
NEWAPI_API_KEY=

# 通用文本模型 API key。foss e2e 与兼容 OpenAI 的模型适配器会读取该变量。
MODEL_API_KEY=your_model_api_key

# 模型网关模式：official 使用官方渠道 + NEWAPI_API_KEY；custom 使用前端初始化、本地 SQLite 或 NEWAPI_BASE_URL/NEWAPI_API_KEY 中的用户自配 NewAPI。
# MODEL_GATEWAY_MODE=official

# CE 用户自部署 NewAPI 配置向导。开启后，前端可初始化 NewAPI、创建/复用调用令牌并写入渠道。
NEWAPI_PROVISIONER_ENABLED=true

# NewAPI 管理地址，不带 /v1；用于 /api/channel/ 和 /api/token/ 管理接口。
NEWAPI_ADMIN_BASE_URL=http://127.0.0.1:3000

# NewAPI 自己的数据库连接；PostgreSQL/MySQL/SQLite 均支持。
# SQLite 必须显式指向已存在的 NewAPI 数据库文件，不会自动创建空库。
# 示例：
# NEWAPI_SQL_DSN=local
# NEWAPI_SQLITE_PATH=/absolute/path/to/new-api/one-api.db
NEWAPI_SQL_DSN=
NEWAPI_SQLITE_PATH=
NEWAPI_ADMIN_USERNAME=root

NEWAPI_PROVISIONER_INIT_TIMEOUT_MS=120000
NEWAPI_RELAY_TOKEN_NAME=dramaclaw-ce-runtime

# 是否让 newAPI 文本模型客户端读取系统代理。默认 true。
# 本地 Surge 系统代理影响内网 newAPI 时可设为 false。
# NEWAPI_TEXT_TRUST_ENV=false

# newAPI 文本模型 HTTP 超时时间，单位秒。
NEWAPI_TEXT_TIMEOUT_SECONDS=120

# Hermes / 虾导聊天模型。默认通过 NEWAPI_BASE_URL + NEWAPI_API_KEY 走 custom provider。
HERMES_MODEL=DC-hermes-LLM
HERMES_MODEL_PROVIDER=custom
HERMES_MODEL_API_MODE=chat_completions
HERMES_MODEL_CONTEXT_LENGTH=131072
# Optional explicit Hermes endpoint override. Normally leave unset so Hermes
# follows the UI-selected NewAPI gateway in local settings.db.
# HERMES_MODEL_BASE_URL=


# =============================================================================
# 2. newAPI 参考媒体 OSS relay
# =============================================================================

# 本地参考图需要先上传到 OSS relay，再把短期签名 URL 传给 newAPI/上游。
# CE 前端保存 OSS relay 配置后，本地 SQLite 配置优先生效。
MEDIA_RELAY_PROVIDER=aliyun_oss

# 签名 URL 默认有效期，单位秒。CE 前端保存后，本地 SQLite 配置优先生效。
MEDIA_RELAY_TTL_SECONDS=1800

# relay bucket 固定给 newAPI 参考媒体使用。CE 前端保存后，本地 SQLite 配置优先生效。
OSS_RELAY_ENDPOINT=oss-cn-chengdu.aliyuncs.com
OSS_RELAY_BUCKET=claymore-llm-relay
OSS_RELAY_AK=
OSS_RELAY_SK=

# 可选：使用 Cloudinary 作为参考媒体 relay。将 MEDIA_RELAY_PROVIDER 设为 cloudinary 后生效。
CLOUDINARY_RELAY_CLOUD_NAME=
CLOUDINARY_RELAY_API_KEY=
CLOUDINARY_RELAY_API_SECRET=
CLOUDINARY_RELAY_FOLDER=


# =============================================================================
# 3. Cognee 知识图谱
# =============================================================================

# 导入小说 / cognify / memify 使用的 LLM。
COGNEE_LLM_PROVIDER=newapi
COGNEE_LLM_MODEL=DC-cognee-LLM

# 留空表示不向 newAPI 透传 reasoning_effort。
COGNEE_LLM_THINKING_LEVEL=high

# 跳过 Cognee 启动连接预检，真实请求仍会走 newAPI。
COGNEE_SKIP_CONNECTION_TEST=true

# 导入小说 embedding 使用的模型。
COGNEE_EMBEDDING_PROVIDER=newapi
COGNEE_EMBEDDING_MODEL=DC-cognee-embedding
COGNEE_EMBEDDING_DIM=1024

# Cognee embedding 单次请求文本条数。官方默认使用 10，兼容 Qwen / 阿里等低 input 上限模型。
# 如果上游 embedding 模型支持更大批量，可以按需调高。
EMBEDDING_BATCH_SIZE=10

# COGNEE_EMBEDDING_MODEL 是 newAPI 内部模型名；需要在模型配置页映射到真实上游 embedding 模型。
# false 表示 dimensions 只用于本地向量库 sizing，不传给上游。
COGNEE_EMBEDDING_SEND_DIMENSIONS=false


# =============================================================================
# 4. newAPI 文本模型
# =============================================================================

# 镜头页 / AI 优化提示词。
GLOBAL_VIDEO_OPTIMIZER_MODEL=DC-video-prompt-optimizer-LLM
GLOBAL_VIDEO_OPTIMIZER_THINKING_LEVEL=low

# 镜头页 / Seedance 2.0 面板 / AI 优化。
SEEDANCE2_PROMPT_COMPOSER_MODEL=DC-seedance2-prompt-composer-LLM
SEEDANCE2_PROMPT_COMPOSER_THINKING_LEVEL=low

# 草图 / AI 检测身份与道具颜色标记。
GLOBAL_VIDEO_IDENTITY_DETECTOR_MODEL=DC-video-identity-detector-LLM
GLOBAL_VIDEO_IDENTITY_DETECTOR_THINKING_LEVEL=low

# 剧集详情 / AI 规划身份 / 出场角色筛选。
IDENTITY_PLANNER_CAST_MODEL=DC-identity-cast-planner-LLM
IDENTITY_PLANNER_CAST_THINKING_LEVEL=low

# 剧集详情 / AI 规划身份 / 默认身份与其他身份分析。
IDENTITY_PLANNER_ANALYSIS_MODEL=DC-identity-analysis-planner-LLM
IDENTITY_PLANNER_ANALYSIS_THINKING_LEVEL=high

# 剧集详情 / AI 规划身份 / 新身份服装造型描述。
IDENTITY_PLANNER_APPEARANCE_MODEL=DC-identity-appearance-writer-LLM
IDENTITY_PLANNER_APPEARANCE_THINKING_LEVEL=high

# 剧集详情 / 逐行生成。
LITERAL_BEAT_META_MODEL=DC-literal-beat-meta-LLM
LITERAL_BEAT_META_THINKING_LEVEL=low

# 场景库 / 从图谱构建 / 场景解析、规范化与 environment_prompt 生成。
SCENE_BUILD_MODEL=DC-scene-builder-LLM
SCENE_BUILD_THINKING_LEVEL=high

# 剧集详情 / 规划场景。
EPISODE_SCENE_PLANNER_MODEL=DC-episode-scene-planner-LLM
EPISODE_SCENE_PLANNER_THINKING_LEVEL=low

# 剧集详情 / 规划道具。
EPISODE_PROP_PLANNER_MODEL=DC-episode-prop-planner-LLM
EPISODE_PROP_PLANNER_THINKING_LEVEL=low

# Freezone / 文本提示词中英互译。
FREEZONE_TRANSLATION_MODEL=DC-freezone-translator-LLM

# Freezone / 故事脚本生成。
FREEZONE_STORY_SCRIPT_MODEL=DC-freezone-story-script-writer-LLM

# Freezone 画布 payload 上限，单位字节。
FREEZONE_CANVAS_PAYLOAD_LIMIT_BYTES=5242880

# 风格页 / 上传参考图创建自定义风格。
STYLE_ANALYZER_MODEL=DC-style-analyzer-LLM

# 内容改写 / 原文转短视频口播逐行文本。
CONTENT_REWRITER_MODEL=DC-content-rewriter-LLM
CONTENT_REWRITER_THINKING_LEVEL=medium

# 剧本规范化。
SCREENPLAY_NORMALIZER_MODEL=DC-screenplay-normalizer-LLM
SCREENPLAY_NORMALIZER_THINKING_LEVEL=low

# 2.0 资产编译 / 基础场景资产校对。
EPISODE_SCENE_RECONCILE_MODEL=DC-episode-scene-reconciler-LLM
EPISODE_SCENE_RECONCILE_THINKING_LEVEL=low

# 2.0 资产编译 / 解说剧场景资产规划。
NARRATED_SCENE_ASSET_MODEL=DC-narrated-scene-asset-planner-LLM
NARRATED_SCENE_ASSET_THINKING_LEVEL=low

# DirectorWorld / Freezone AI 临时道具规划。
STAGING_PROP_MODEL=DC-staging-prop-planner-LLM
STAGING_PROP_THINKING_LEVEL=low
STAGING_PROP_TIMEOUT_SECONDS=120


# =============================================================================
# 5. newAPI 图片模型
# =============================================================================

# DC-Image-2 逻辑模型；gpt-image-2/image-2 类模型会按场景透传 quality。
NEWAPI_IMAGE_MODEL=gpt-image-2

# DC-Banana-2 逻辑模型；nano-banana-2/nb-2 不透传 quality。
NEWAPI_NANOBANANA2_MODEL=nano-banana-2

# 角色图默认模型。
DEFAULT_CHARACTER_IMAGE_SELECTION=newapi_gpt_image2

# 镜头草图默认模型。
DEFAULT_SKETCH_IMAGE_SELECTION=newapi_gpt_image2

# 镜头 render 默认模型。
DEFAULT_RENDER_IMAGE_SELECTION=newapi_gpt_image2

# 项目资产 / 道具三视图参考图 reference_3view.png。
PROP_REF_IMAGE_PROVIDER=newapi
PROP_REF_IMAGE_MODEL=gpt-image-2

# 项目资产 / 源图 master.png，纯文本生成。
SCENE_MASTER_IMAGE_PROVIDER=newapi
SCENE_MASTER_IMAGE_MODEL=nano-banana-2

# 项目资产 / reverse_master.png，使用 master.png 作为参考图。
SCENE_REVERSE_MASTER_IMAGE_PROVIDER=newapi
SCENE_REVERSE_MASTER_IMAGE_MODEL=nano-banana-2

# 项目资产 / pano_360.png，使用 master/reverse 参考图，2:1 全景。
SCENE_360_IMAGE_PROVIDER=newapi
SCENE_360_IMAGE_MODEL=gpt-image-2


# =============================================================================
# 6. 图像基础参数
# =============================================================================

IMAGE_DEFAULT_WIDTH=1440
IMAGE_DEFAULT_HEIGHT=2560
IMAGE_DEFAULT_STYLE=chinese_period_drama


# =============================================================================
# 7. newAPI 视频模型
# =============================================================================

# 默认视频生成后端。
VIDEO_BACKEND=newapi_seedance-1.0-pro-fast

# 页面可选的 newAPI 视频模型。
NEWAPI_VIDEO_MODELS=seedance-1.0-pro-fast,seedance-1.5-pro,seedance-2.0,seedance-2.0-fast,seedance-2.0-value,seedance-2.0-fast-value,happyhorse-1.0,grok-video-channel

# 默认视频模型。
DEFAULT_VIDEO_MODEL=seedance-1.0-pro-fast
NEWAPI_VIDEO_MODEL=seedance-1.0-pro-fast

# 默认视频分辨率。
NEWAPI_VIDEO_RESOLUTION=720p

# auto 表示按模型和 beat 类型决定是否生成同步音频。
NEWAPI_VIDEO_GENERATE_AUDIO=auto

# 支持 generate_audio 的视频模型。
NEWAPI_VIDEO_AUDIO_MODELS=seedance-1.5-pro,seedance-2.0,seedance-2.0-fast,seedance-2.0-value,seedance-2.0-fast-value

# 各视频模型允许的 duration 范围，单位秒。
NEWAPI_VIDEO_DURATION_BOUNDS=seedance-1.0-pro-fast:2-12,seedance-1.5-pro:4-12,seedance-2.0:4-15,seedance-2.0-fast:4-15,seedance-2.0-value:4-15,seedance-2.0-fast-value:4-15,happyhorse-1.0:3-15,grok-video-channel:6-30


# =============================================================================
# 8. newAPI 音频模型
# =============================================================================

# beat 音频生成使用 IndexTTS2；参考声线按 v2.0 逻辑传入。
INDEXTTS2_PROVIDER=newapi
INDEXTTS2_NEWAPI_MODEL=index-tts-2

# 音频生成 HTTP 超时时间，单位秒。
INDEXTTS2_TIMEOUT_SECONDS=1800


# =============================================================================
# 9. 视频基础参数
# =============================================================================

VIDEO_FPS=30
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_CODEC=libx264
VIDEO_AUDIO_CODEC=aac
VIDEO_BITRATE=4M


# =============================================================================
# 10. UI 配置
# =============================================================================


# BuilderGPT Director viewer 对浏览器可访问的地址。
# 局域网协作时改为本机 LAN IP，例如 http://192.168.2.206:9024。
DIRECTOR_VIEWER_URL=http://127.0.0.1:9024

# operator 操作口令：护「导出提示词」与「图像生成防护闸」。
# 必须设为你自己的非默认值；留空 = 这些受护动作一律拒绝(无公开默认口令)。
PROMPT_EXPORT_PASSWORD=change_me

# 版本/功能更新通知。false = 完全关闭 release feed,不读包内 notes、不访问 GitHub。
RELEASE_NOTIFICATIONS_ENABLED=true

# 可选 GitHub token,用于提高 GitHub releases/latest 查询限流额度；留空走匿名请求。
RELEASE_NOTIFICATIONS_GITHUB_TOKEN=


# =============================================================================
# 11. 输出目录
# =============================================================================

NOVELVIDEO_OUTPUT_DIR=output
